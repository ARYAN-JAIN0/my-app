generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL_SQLITE")
}

enum LeadLifecycle {
  imported
  validated
  duplicate_filtered
  queued
  scored
  draft_generated
  pending_approval
  approved
  sent
  replied
  negotiating
  won
  lost
  paused
  rejected
}

enum MessageLifecycle {
  draft
  saved
  pending_approval
  approved
  sending
  sent
  failed
  rejected
  edited
}

enum ImportJobStatus {
  queued
  processing
  completed
  failed
}

enum ImportRowStatus {
  imported
  duplicate
  invalid
  failed
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum ReplyIntent {
  interested
  not_interested
  objection
  pricing
  meeting
  unknown
}

enum FollowupStatus {
  scheduled
  sent
  skipped
  cancelled
}

enum JobRunStatus {
  queued
  running
  completed
  failed
  cancelled
}

model User {
  id             String            @id @default(cuid())
  email          String            @unique
  name           String
  role           String            @default("owner")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  gmailAccounts  GmailAccount[]
  businessProfile BusinessProfile?
  offers         Offer[]
  leads          Lead[]
  importJobs     ImportJob[]
  approvals      Approval[]
  knowledgeRules KnowledgeRule[]
  analyticsEvents AnalyticsEvent[]
  followups      Followup[]
  threads        Thread[]
  messages       Message[]
  emailTemplates EmailTemplate[]
  jobRuns        JobRun[]
  activityLogs   ActivityLog[]
  featureStatuses FeatureStatus[]
  healthChecks   HealthCheckResult[]
  systemSettings SystemSetting[]
  aiProviderSettings AIProviderSetting[]
  aiConnectionTests AIConnectionTestResult[]
  stressTestRuns StressTestRun[]
}

model GmailAccount {
  id             String   @id @default(cuid())
  userId         String
  email          String
  accessToken    String?
  refreshToken   String?
  expiryDate     DateTime?
  scope          String?
  connectedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, email])
}

model BusinessProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  companyName    String
  valueProp      String
  toneRules      String
  pricingRules   String
  objectionRules String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Offer {
  id             String   @id @default(cuid())
  userId         String
  name           String
  description    String
  price          Float?
  currency       String?  @default("USD")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
}

model Lead {
  id                String         @id @default(cuid())
  userId            String
  firstName         String
  lastName          String
  email             String
  phone             String?
  company           String
  title             String?
  source            String?
  priority          String         @default("medium")
  score             Int?
  confidenceScore   Float?
  signalBreakdown   Json?
  notes             String?
  tags              Json?
  lifecycle         LeadLifecycle  @default(imported)
  lastContactedAt   DateTime?
  lastRepliedAt     DateTime?
  needsAction       Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages          Message[]
  approvals         Approval[]
  followups         Followup[]
  threadLinks       ThreadLead[]
  importRows        ImportRow[]

  @@index([userId, lifecycle])
  @@index([userId, score])
  @@index([userId, needsAction])
  @@unique([userId, email, company])
}

model Thread {
  id              String       @id @default(cuid())
  userId          String
  gmailThreadId   String?      @unique
  subject         String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        Message[]
  leads           ThreadLead[]

  @@index([userId, updatedAt])
}

model ThreadLead {
  threadId        String
  leadId          String
  linkedAt        DateTime @default(now())
  thread          Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@id([threadId, leadId])
  @@index([leadId])
}

model Message {
  id                String            @id @default(cuid())
  userId            String
  leadId            String
  threadId          String?
  gmailMessageId    String?           @unique
  fromEmail         String?
  toEmail           String?
  subject           String
  body              String
  lifecycle         MessageLifecycle  @default(draft)
  direction         String            @default("outbound")
  aiSummary         String?
  replyIntent       ReplyIntent?
  metadata          Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  sentAt            DateTime?

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead              Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  thread            Thread?           @relation(fields: [threadId], references: [id], onDelete: SetNull)
  approvals         Approval[]

  @@index([leadId, createdAt])
  @@index([threadId, createdAt])
  @@index([userId, lifecycle])
  @@index([direction, createdAt])
}

model Approval {
  id                String         @id @default(cuid())
  userId            String
  leadId            String
  messageId         String
  status            ApprovalStatus @default(pending)
  reviewerNote      String?
  reviewedAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead              Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  message           Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([leadId])
  @@index([messageId])
}

model ImportJob {
  id                String         @id @default(cuid())
  userId            String
  filename          String
  status            ImportJobStatus @default(queued)
  stage             String         @default("queued")
  progress          Int            @default(0)
  totalRows         Int            @default(0)
  importedRows      Int            @default(0)
  duplicateRows     Int            @default(0)
  invalidRows       Int            @default(0)
  errorRows         Int            @default(0)
  errorMessage      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  completedAt       DateTime?
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  rows              ImportRow[]

  @@index([userId, createdAt])
  @@index([status])
}

model ImportRow {
  id                String         @id @default(cuid())
  importJobId       String
  leadId            String?
  rowNumber         Int
  status            ImportRowStatus
  rawData           Json
  errorReason       String?
  createdAt         DateTime       @default(now())
  importJob         ImportJob      @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  lead              Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([importJobId, rowNumber])
  @@index([status])
}

model KnowledgeRule {
  id                String         @id @default(cuid())
  userId            String
  category          String
  title             String
  content           String
  active            Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks            KnowledgeChunk[]

  @@index([userId, category])
  @@index([active])
}

model KnowledgeChunk {
  id                String         @id @default(cuid())
  knowledgeRuleId   String
  chunkIndex        Int
  content           String
  tokenCount        Int?
  embedding         Json?
  createdAt         DateTime       @default(now())
  knowledgeRule     KnowledgeRule  @relation(fields: [knowledgeRuleId], references: [id], onDelete: Cascade)

  @@unique([knowledgeRuleId, chunkIndex])
  @@index([knowledgeRuleId])
}

model AnalyticsEvent {
  id                String         @id @default(cuid())
  userId            String
  type              String
  leadId            String?
  messageId         String?
  metadata          Json?
  createdAt         DateTime       @default(now())
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
  @@index([leadId])
  @@index([messageId])
}

model Followup {
  id                String         @id @default(cuid())
  userId            String
  leadId            String
  dayOffset         Int
  dueAt             DateTime
  sentAt            DateTime?
  status            FollowupStatus @default(scheduled)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead              Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([status, dueAt])
  @@unique([leadId, dayOffset])
}

model ProcessingEvent {
  id                String         @id @default(cuid())
  userId            String
  eventType         String
  leadId            String?
  messageId         String?
  importJobId       String?
  payload           Json?
  createdAt         DateTime       @default(now())

  @@index([userId, eventType, createdAt])
  @@index([leadId])
  @@index([messageId])
  @@index([importJobId])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  userId      String
  name        String
  category    String   @default("outbound")
  subject     String
  body        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, active])
  @@unique([userId, name])
}

model JobRun {
  id             String       @id @default(cuid())
  userId         String
  jobType        String
  status         JobRunStatus @default(queued)
  stage          String?
  progress       Int          @default(0)
  totalCount     Int?
  processedCount Int?
  successCount   Int          @default(0)
  failureCount   Int          @default(0)
  errorMessage   String?
  metadata       Json?
  startedAt      DateTime     @default(now())
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  stressMetrics  StressTestMetric[]

  @@index([userId, jobType, createdAt])
  @@index([status, updatedAt])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  actionKey   String
  component   String?
  requestPath String?
  service     String?
  leadId      String?
  messageId   String?
  importJobId String?
  jobRunId    String?
  status      String
  durationMs  Int?
  details     Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([actionKey, createdAt])
  @@index([leadId])
  @@index([jobRunId])
}

model FeatureStatus {
  id                 String   @id @default(cuid())
  userId             String
  featureKey         String
  route              String?
  backendEndpoint    String?
  description        String
  status             String
  dependencies       Json?
  notes              String?
  lastSuccessAt      DateTime?
  lastCheckedAt      DateTime?
  automatedVerified  Boolean  @default(false)
  manualVerified     Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureKey])
  @@index([status, updatedAt])
}

model HealthCheckResult {
  id         String   @id @default(cuid())
  userId     String
  checkKey   String
  status     String
  latencyMs  Int?
  message    String?
  details    Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, checkKey, createdAt])
  @@index([status, createdAt])
}

model SystemSetting {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([updatedAt])
}

model AIProviderSetting {
  id               String   @id @default(cuid())
  userId           String
  provider         String
  enabled          Boolean  @default(false)
  baseUrl          String?
  apiKey           String?
  model            String?
  fallbackProvider String?
  fallbackModel    String?
  mode             String?  @default("local-first")
  temperature      Float?   @default(0.3)
  timeoutMs        Int?     @default(30000)
  retries          Int?     @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([enabled, updatedAt])
}

model AIConnectionTestResult {
  id         String   @id @default(cuid())
  userId     String
  provider   String
  success    Boolean
  latencyMs  Int?
  message    String?
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider, createdAt])
}

model StressTestRun {
  id              String   @id @default(cuid())
  userId          String
  name            String
  status          JobRunStatus @default(queued)
  leadCount       Int
  mode            String
  avgLatencyMs    Float?
  p95LatencyMs    Float?
  successCount    Int      @default(0)
  failureCount    Int      @default(0)
  queueDepth      Int?
  slowestEndpoint String?
  notes           String?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics         StressTestMetric[]

  @@index([userId, createdAt])
  @@index([status, updatedAt])
}

model StressTestMetric {
  id              String   @id @default(cuid())
  stressTestRunId String
  jobRunId        String?
  name            String
  value           Float
  unit            String?
  metadata        Json?
  createdAt       DateTime @default(now())
  stressTestRun   StressTestRun @relation(fields: [stressTestRunId], references: [id], onDelete: Cascade)
  jobRun          JobRun?  @relation(fields: [jobRunId], references: [id], onDelete: SetNull)

  @@index([stressTestRunId, createdAt])
  @@index([jobRunId])
}

